{
  "name": "@phantasy/plugin-telegram",
  "version": "2.0.0",
  "private": false,
  "description": "Telegram bot and channel integration plugin for Phantasy companions.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "phantasy.plugin.json"
  ],
  "sideEffects": false,
  "keywords": [
    "telegram",
    "messaging",
    "bot",
    "community"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phantasy-bot/plugin-telegram"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/phantasy-bot/plugin-telegram",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@phantasy/agent": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2"
  },
  "phantasy": {
    "displayName": "Telegram",
    "category": "messaging",
    "tags": [
      "telegram",
      "messaging",
      "bot",
      "community"
    ],
    "workspace": "business",
    "extensionKind": "integration",
    "permissions": [
      "internet"
    ],
    "pluginDependencies": [],
    "platforms": [
      "node"
    ],
    "productionReady": false,
    "adminSurface": {
      "tabId": "telegram",
      "label": "Telegram",
      "section": "business",
      "workspace": "business",
      "kind": "generic",
      "keywords": [
        "telegram",
        "messaging",
        "bot",
        "community"
      ]
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
